# GEMINI_API_KEY: Required for Gemini AI API calls on the backend.
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# FIREBASE_SERVICE_ACCOUNT_KEY: Required for the cleanup script in scripts/cleanup.ts.
# Get this from Firebase Console > Project Settings > Service Accounts.
# Copy the JSON and paste it as a single line or as a secret in GitHub.
FIREBASE_SERVICE_ACCOUNT_KEY=

# FIRESTORE_DATABASE_ID: The ID of your Firestore database.
# Found in firebase-applet-config.json.
FIRESTORE_DATABASE_ID=
